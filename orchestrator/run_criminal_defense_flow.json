{
  "scenario_id": "run_criminal_defense_flow",
  "description": "تشغيل مسار الدعوى الجنائية من التحليل إلى الدفاع ثم المذكرات",
  "entry_engine": {
    "id": "criminal_law_index",
    "folder": "engines/criminal_law"
  },
  "flow": [
    {
      "step": "analyze_case",
      "engine": {
        "id": "criminal_law_index",
        "folder": "engines/criminal_law"
      },
      "output": "case_elements"
    },
    {
      "step": "generate_defense",
      "engine": {
        "id": "defense_index",
        "folder": "engines/defense"
      },
      "input": "case_elements",
      "output": "defense_arguments"
    },
    {
      "step": "generate_pleading",
      "engine": {
        "id": "pleadings_index",
        "folder": "engines/pleadings"
      },
      "input": "defense_arguments",
      "output": "draft_pleading"
    }
  ],
  "status": "draft"
}
